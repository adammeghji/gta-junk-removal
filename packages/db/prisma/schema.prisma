generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
}

model Booking {
  id          String        @id @default(cuid())
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime
  address     String
  city        String
  postalCode  String
  notes       String?
  estimatedVolumeCuFt Float?
  quoteAmount Float?
  finalAmount Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  jobs        Job[]
}

model Job {
  id        String    @id @default(cuid())
  bookingId String
  booking   Booking   @relation(fields: [bookingId], references: [id])
  status    JobStatus @default(ASSIGNED)
  crewIds   String[]
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum JobStatus {
  ASSIGNED
  EN_ROUTE
  ON_SITE
  COMPLETED
  CANCELLED
}
